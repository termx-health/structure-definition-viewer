{
  "name": "@kodality-web/structure-definition-viewer",
  "version": "5.0.7",
  "type": "module",
  "main": "./dist/structure-definition-viewer.umd.cjs",
  "module": "./dist/structure-definition-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/structure-definition-viewer.js",
